DATABASE_URL=postgresql+psycopg://empresa_ia:empresa_ia@localhost:5432/empresa_ia
JWT_SECRET=troque-este-valor
JWT_ACCESS_TTL_MIN=30
JWT_REFRESH_TTL_DAYS=14
STORAGE_BACKEND=filesystem
STORAGE_ROOT=./storage_local
CORS_ORIGINS=http://localhost:5173,http://localhost:8080

# ───────── Provedores de IA ─────────
# Modelos NUNCA ficam fixos no código — alteráveis aqui.

# Google Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Groq
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# OpenRouter
OPENROUTER_API_KEY=
OPENROUTER_MODEL=deepseek/deepseek-chat-v3

# Hugging Face
HUGGINGFACE_API_KEY=
HF_MODEL=black-forest-labs/FLUX.1-schnell

# Fal.ai
FAL_KEY=
FAL_MODEL=flux/schnell
FAL_VIDEO_MODEL=fal-ai/minimax-video

# ───────── Modelos especializados (Fase 5.1) — opcionais ─────────
GEMINI_VISION_MODEL=
OPENROUTER_VISION_MODEL=
HF_OCR_MODEL=microsoft/trocr-large-printed
HF_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
HF_BACKGROUND_MODEL=briaai/RMBG-1.4
HF_VISION_MODEL=Salesforce/blip-image-captioning-large

# Replicate (reservado — Fase 6)
REPLICATE_API_KEY=
REPLICATE_IMAGE_MODEL=
REPLICATE_UPSCALE_MODEL=
REPLICATE_INPAINT_MODEL=

# ───────── Perfis e Modo de Roteamento ─────────
IA_PROFILE=production
IA_MODO=automatico

# ───────── Observabilidade (Fase 6) ─────────
# DEBUG=true habilita stacktrace nas respostas e modo dev permissivo.
DEBUG=false
LOG_LEVEL=INFO        # DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_JSON=false        # true em produção (Loki/ELK/Grafana)
LOG_COLOR=true        # cores ANSI em DEV (auto-desabilitadas se não-TTY)
