{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://caetusos.local/contracts/execution-plan.schema.json",
  "title": "Execution Plan - Caetus OS",
  "description": "Formato oficial de um Execution Plan. Ver ai/contracts/execution-plan-schema.md para a explicação completa de cada campo.",
  "type": "object",
  "required": ["formato_versao", "plan_id", "criado_em", "origem", "estrategia_execucao", "etapas"],
  "additionalProperties": false,
  "properties": {
    "formato_versao": { "type": "string" },
    "plan_id": { "type": "string" },
    "criado_em": { "type": "string", "format": "date-time" },
    "origem": {
      "type": "object",
      "required": ["pedido_usuario", "resolvido_por", "capability_ou_workflow"],
      "additionalProperties": false,
      "properties": {
        "pedido_usuario": { "type": "string" },
        "resolvido_por": { "type": "string" },
        "capability_ou_workflow": { "type": "string" }
      }
    },
    "estrategia_execucao": {
      "type": "string",
      "enum": ["sequencial", "paralela-quando-possivel"]
    },
    "etapas": {
      "type": "array",
      "items": { "$ref": "#/$defs/etapa" }
    }
  },
  "$defs": {
    "etapa": {
      "type": "object",
      "required": ["id", "capability", "depende_de", "entrada", "condicao", "tratamento_de_erro"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string" },
        "capability": { "type": "string" },
        "depende_de": {
          "type": "array",
          "items": { "type": "string" }
        },
        "entrada": { "type": "object" },
        "condicao": { "type": ["string", "null"] },
        "tratamento_de_erro": {
          "type": "object",
          "required": ["retentativas_maximas", "apos_esgotar_retentativas"],
          "additionalProperties": false,
          "properties": {
            "retentativas_maximas": { "type": "integer", "minimum": 0 },
            "apos_esgotar_retentativas": {
              "type": "string",
              "enum": ["abortar_plano", "pular_dependentes"]
            }
          }
        }
      }
    }
  }
}
